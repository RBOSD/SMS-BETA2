# SMS 開立事項系統 - 環境變數範例
# 複製此檔為 .env 並填入實際數值

# 資料庫連線（Supabase PostgreSQL）
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Session 密鑰（生產環境必設，至少 32 字元）
# 產生方式：openssl rand -base64 32
SESSION_SECRET=your-random-secret-key-at-least-32-chars

# 選用：Gemini AI API（若使用 AI 審查功能）
# GEMINI_API_KEY=your-gemini-api-key

# 選用：環境標識（production 會啟用嚴格檢查）
# NODE_ENV=production
