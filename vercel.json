{
  "version": 2,
  "installCommand": "npm install && npm run build:vercel",
  "builds": [{"src": "server.js", "use": "@vercel/node"}],
  "routes": [{"src": "/(.*)", "dest": "server.js"}],
  "headers": [
    {"source": "/(.*)", "headers": [{"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}]}
  ]
}
