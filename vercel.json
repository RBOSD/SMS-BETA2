{
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "VERCEL=1 npm run build:vercel",
  "builds": [
    {"src": "public/**", "use": "@vercel/static"},
    {"src": "server.js", "use": "@vercel/node"}
  ],
  "rewrites": [
    {"source": "/app/(.*)", "destination": "/app/$1"},
    {"source": "/(.*)", "destination": "/server.js"}
  ],
  "headers": [
    {"source": "/app/assets/(.*)", "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]},
    {"source": "/(.*)", "headers": [{"key": "Cache-Control", "value": "no-store, no-cache, must-revalidate"}]}
  ]
}
